<Window
    CanMaximize="False"
    MaxHeight="500"
    MaxWidth="400"
    MinHeight="100"
    MinWidth="80"
    Title="DesktopFilesGui"
    x:Class="DesktopFilesGui.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:avaloniaEdit="https://github.com/avaloniaui/avaloniaedit"
    xmlns:controls="clr-namespace:DesktopFilesGui.Controls"
    xmlns:converters="clr-namespace:DesktopFilesGui.Converters"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="using:DesktopFilesGui.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.Resources>
        <sys:Double x:Key="TextBoxWidth">300</sys:Double>
        <sys:Double x:Key="ButtonSize">50</sys:Double>
        <sys:Double x:Key="IconWidth">20</sys:Double>
    </Window.Resources>

    <Grid RowDefinitions="Auto,*,Auto">
        <Menu Grid.Row="0">
            <MenuItem Header="Open">
                <MenuItem Header="Open desktop files in 'Files'" Icon="{icons:MaterialIconExt Kind=Files}" />
                <MenuItem Header="Show list of the desktop file" Icon="{icons:MaterialIconExt Kind=ListBox}" />
                <MenuItem Header="Open desktop file" Icon="{icons:MaterialIconExt Kind=OpenInApp}" />
            </MenuItem>
            <MenuItem Header="Services">
                <MenuItem
                    Click="CloseApp"
                    Header="Close the app"
                    Icon="{icons:MaterialIconExt Kind=Close}" />
                <MenuItem Header="Open github source" Icon="{icons:MaterialIconExt Kind=Github}" />
            </MenuItem>
            <MenuItem Header="Themes" Icon="{icons:MaterialIconExt Kind=Theme}" />
        </Menu>

        <ScrollViewer Grid.Row="1" Margin="5,0,0,0">
            <StackPanel>
                <TextBlock Margin="0,15,0,0" Text="Main configuration" />

                <!--  Main inputs  -->
                <StackPanel Orientation="Horizontal">
                    <icons:MaterialIcon
                        Kind="Rename"
                        Margin="5,0,10,0"
                        Width="{StaticResource IconWidth}" />
                    <TextBox Watermark="Desktop file name" Width="{StaticResource TextBoxWidth}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <icons:MaterialIcon
                        Kind="File"
                        Margin="5,0,10,0"
                        Width="{StaticResource IconWidth}" />
                    <TextBox Watermark="Path to file" Width="{StaticResource TextBoxWidth}" />
                    <Button
                        Content="{icons:MaterialIconExt Kind=Search}"
                        Height="{StaticResource ButtonSize}"
                        Margin="5,0,10,0"
                        Width="{StaticResource ButtonSize}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <icons:MaterialIcon
                        Kind="ImageAdd"
                        Margin="5,0,10,0"
                        Width="{StaticResource IconWidth}" />
                    <TextBox Watermark="Path to icon" Width="{StaticResource TextBoxWidth}" />
                    <Button
                        Content="{icons:MaterialIconExt Kind=Search}"
                        Height="{StaticResource ButtonSize}"
                        Margin="5,0,10,0"
                        Width="{StaticResource ButtonSize}" />
                </StackPanel>

                <Separator />
                <TextBlock Margin="0,15,0,0" Text="Boolean configuration" />


                <controls:CheckBoxWithHelp Content="Show terminal" ToolTip="Allows terminal to appear after application start" />
                <controls:CheckBoxWithHelp Content="Require sudo" ToolTip="Runs application with super user rights" />
                <controls:CheckBoxWithHelp
                    Content="Display in menu"
                    IsChecked="True"
                    ToolTip="If unchecked, do not show in the menu" />
                <controls:CheckBoxWithHelp
                    Content="Enable localization"
                    IsChecked="{Binding EnableLocalization}"
                    ToolTip="If checked, replace application name text box to new, with localization support" />

                <Separator />
                <TextBlock Margin="0,15,0,0" Text="Localizable configuration" />

                <controls:LocalizableField
                    EnableLocalization="{Binding EnableLocalization}"
                    Icon="Application"
                    Watermark="Application name" />

                <controls:LocalizableField
                    EnableLocalization="{Binding EnableLocalization}"
                    Icon="CommentAdd"
                    Watermark="Comment" />

                <controls:LocalizableField
                    EnableLocalization="{Binding EnableLocalization}"
                    Icon="FileWord"
                    Watermark="Keywords (';' divided)" />

                <controls:LocalizableField
                    EnableLocalization="{Binding EnableLocalization}"
                    Icon="ImageDescription"
                    Watermark="Generic name" />

                <Separator />
                <TextBlock Margin="0,15,0,0" Text="Extended configuration" />

                <controls:CheckBoxWithHelp Content="Is hidden" ToolTip="Hide application in the menu (useful if application is removed)" />

                <Separator />
                <TextBlock Margin="0,15,0,0" Text="Professional configuration" />

                <controls:CheckBoxWithHelp Content="Run from D-BUS" ToolTip="Mark that application will be run from D-BUS" />
                <controls:CheckBoxWithHelp Content="Startup notify support" ToolTip="Mark that application support startup notifications" />
                <controls:CheckBoxWithHelp Content="Custom 'exec' command" ToolTip="Allows user write custom 'exec' command to run application" />

                <StackPanel Orientation="Horizontal">
                    <icons:MaterialIcon
                        Kind="Files"
                        Margin="5,0,10,0"
                        Width="{StaticResource IconWidth}" />
                    <TextBox Watermark="Supported MIME types (';' divided)" Width="{StaticResource TextBoxWidth}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" RowDefinitions="*,Auto">
            <Button
                Command="{Binding ChangeCodePopupVisibilityCommand}"
                Content="{icons:MaterialIconExt Kind=Code}"
                CornerRadius="30"
                Grid.Row="1"
                Height="{StaticResource ButtonSize}"
                HorizontalAlignment="Right"
                Margin="15"
                Width="{StaticResource ButtonSize}"
                x:Name="CodeButton" />
            <Popup
                Grid.Row="1"
                Height="200"
                IsLightDismissEnabled="True"
                IsOpen="{Binding IsCodePopupVisible}"
                Placement="Right"
                PlacementTarget="{Binding ElementName=CodeButton}"
                Width="300"
                x:Name="CodePopup">
                <Border BoxShadow="0 50 rgba(0,0,0,0.3)">
                    <avaloniaEdit:TextEditor
                        FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                        FontSize="16"
                        IsEnabled="False"
                        Margin="-5,0,0,0"
                        Name="Editor"
                        ShowLineNumbers="True" />
                </Border>
            </Popup>
        </Grid>
    </Grid>
</Window>